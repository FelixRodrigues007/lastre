# Render gateway URL. Felix updates this after Render creates the service URL.
VITE_GATEWAY_URL=https://lastro.onrender.com
VITE_PUBLIC_SITE_URL=https://lastre.io

# App console origin. Must point to the deployed app (not the landing) so the
# landing "Open Sealed Rail" / "App" CTA resolves external instead of falling
# back to the local-dev "/app" proxy path.
VITE_APP_URL=https://app.lastre.io
