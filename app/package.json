{
  "name": "lastro-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev:api": "tsx server/index.ts",
    "dev:web": "vite",
    "dev": "concurrently -k -n api,web -c blue,green \"npm run dev:api\" \"npm run dev:web\"",
    "build": "tsc --noEmit && vite build",
    "build:api": "tsc -p server/tsconfig.build.json",
    "preview": "vite preview",
    "start:api": "node server-dist/index.js",
    "lint": "tsc --noEmit && tsc -p server/tsconfig.json --noEmit"
  },
  "dependencies": {
    "mapbox-gl": "^3.25.0",
    "maplibre-gl": "^5.24.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.3"
  },
  "devDependencies": {
    "@types/mapbox-gl": "^3.4.1",
    "@types/node": "^26.0.1",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.0",
    "tsx": "^4.20.3",
    "typescript": "^7.0.2",
    "vite": "^6.0.7"
  }
}
